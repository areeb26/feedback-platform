# API
PORT=3001
NODE_ENV=production

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/feedback-platform

# Clerk (https://dashboard.clerk.com)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Cloudinary (tenant logo uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Business Profile (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/google/callback

# Google Places (competitor ratings — server-side only)
GOOGLE_PLACES_API_KEY=

# OpenAI (AI reply generation — Phase 5)
OPENAI_API_KEY=

# Platform super-admin (comma-separated Clerk user IDs)
SUPER_ADMIN_USER_IDS=user_...
