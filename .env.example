# API
PORT=3001
NODE_ENV=production

# MongoDB Atlas (required in production)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/feedback-platform

# Clerk (https://dashboard.clerk.com) — use live keys on production VPS
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
# In Clerk Dashboard → User & authentication: disable public sign-ups.
# Client accounts are agency-provisioned when you create a tenant workspace.

# Cloudinary (tenant logo uploads — optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Business Profile (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Dev: http://localhost:5173/google/callback
# Production: https://YOUR_DOMAIN/google/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/google/callback

# Google Places (competitor ratings — server-side only, optional)
GOOGLE_PLACES_API_KEY=

# OpenAI (AI reply generation — optional, Phase 5)
OPENAI_API_KEY=

# Platform super-admin (comma-separated Clerk user IDs — required)
SUPER_ADMIN_USER_IDS=user_...

# Expo mobile app (same Clerk app as web)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# API base URL for Expo app (default http://localhost:3001)
EXPO_PUBLIC_API_URL=http://localhost:3001

# --- GitHub Actions deploy secrets (set in repo Settings → Secrets, not in .env) ---
# DEPLOY_HOST     — VPS public IP or hostname
# DEPLOY_USER     — SSH user with Docker access
# DEPLOY_SSH_KEY  — Private deploy key (PEM)
# DEPLOY_PATH     — App directory on VPS (e.g. /opt/feedback-platform)
